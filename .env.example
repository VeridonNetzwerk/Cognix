# =====================================================
# CogniX environment configuration (example)
# Copy this file to ".env" and edit values.
# Values stored here are bootstrap-only; most runtime
# configuration is editable from the web dashboard and
# stored in the database.
# =====================================================

# ---- Core ----
APP_ENV=production              # development | production
APP_HOST=0.0.0.0
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
TRUST_PROXY=false

# ---- Master encryption key (REQUIRED) ----
# 32-byte base64. Generate with:
#   python -c "import secrets,base64;print(base64.b64encode(secrets.token_bytes(32)).decode())"
MASTER_KEY=

# ---- Auth ----
JWT_SECRET=                     # 64+ char random string
AUTH_PEPPER=                    # additional pepper for password hashing
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# ---- Database ----
# Supported drivers: sqlite, postgresql, mysql
DATABASE_URL=sqlite+aiosqlite:///./data/cognix.db
# Examples:
# DATABASE_URL=postgresql+asyncpg://cognix:secret@db:5432/cognix
# DATABASE_URL=mysql+aiomysql://cognix:secret@db:3306/cognix
# If your password contains '%' characters, keep them URL-encoded (e.g. %25)

# ---- Redis (optional; leave empty to disable IPC/event streaming) ----
REDIS_URL=

# ---- Discord bot (can also be set via setup wizard) ----
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_OWNER_IDS=              # comma-separated

# ---- Google OAuth (optional) ----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/v1/auth/google/callback

# ---- Lavalink (optional, for music cog) ----
LAVALINK_HOST=lavalink
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false

# ---- Frontend ----
FRONTEND_DIR=frontend/.next/standalone
SERVE_FRONTEND=true             # let FastAPI serve the built frontend

# ---- Logging ----
# LOG_LEVEL controls verbosity of both stdout and logs/latest.log.
#   DEBUG    - extremely verbose, includes library noise; use only when troubleshooting
#   INFO     - default, normal operation summary (recommended)
#   WARNING  - abnormal but non-fatal conditions only
#   ERROR    - failed operations only
#   CRITICAL - catastrophic events only (process about to die)
LOG_LEVEL=INFO
LOG_JSON=false
